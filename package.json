{
  "name": "grados",
  "version": "0.2.1",
  "description": "The enrichment-grade MCP server for academic paper search and full-text extraction. For science.",
  "main": "dist/index.js",
  "bin": {
    "grados": "./dist/index.js"
  },
  "files": [
    "dist/",
    "mcp-config.example.json",
    "marker-worker/worker.py",
    "marker-worker/runtime_env.py",
    "marker-worker/prewarm.py",
    "marker-worker/pyproject.toml",
    "marker-worker/.python-version",
    "marker-worker/install.ps1"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "pack:mcpb": "npm run build && mcpb pack"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "academic",
    "papers",
    "research",
    "scopus",
    "pubmed",
    "crossref",
    "web-of-science",
    "springer",
    "sci-hub",
    "pdf",
    "full-text",
    "literature-review"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/STSNaive/GRaDOS.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.39.1"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/form-data": "^2.2.1",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
