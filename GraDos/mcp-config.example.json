{
    "search": {
        "order": [
            "Elsevier",
            "Springer",
            "WebOfScience",
            "Crossref",
            "PubMed"
        ],
        "enabled": {
            "Elsevier": true,
            "Springer": true,
            "WebOfScience": true,
            "Crossref": true,
            "PubMed": true
        }
    },
    "extract": {
        "downloadDirectory": "./downloads",
        "fetchStrategy": {
            "order": ["TDM", "OA", "SciHub", "Headless"],
            "enabled": {
                "TDM": true,
                "OA": true,
                "SciHub": true,
                "Headless": true
            }
        },
        "tdm": {
            "order": ["Elsevier", "Springer"],
            "enabled": {
                "Elsevier": true,
                "Springer": true
            }
        },
        "sciHub": {
            "autoUpdateMirror": true,
            "mirrorUrlFile": "./scihub-mirrors.txt",
            "fallbackMirror": "https://sci-hub.se"
        },
        "headlessBrowser": {
            "browser": "msedge",
            "_comment_browser": "Options: 'msedge', 'chrome', 'firefox'. Maps to default installation paths on Windows.",
            "interactiveCaptchaHelp": true
        },
        "parsing": {
            "markerTimeout": 120000,
            "_comment_markerTimeout": "Maximum time in milliseconds to wait for the local Marker worker process under ./marker-worker (default: 120000).",
            "order": ["LlamaParse", "Marker", "Native"],
            "enabled": {
                "LlamaParse": true,
                "Marker": true,
                "Native": true
            }
        },
        "qa": {
            "minCharacters": 1500
        }
    },
    "apiKeys": {
        "ELSEVIER_API_KEY": "",
        "WOS_API_KEY": "",
        "SPRINGER_meta_API_KEY": "",
        "SPRINGER_OA_API_KEY": "",
        "LLAMAPARSE_API_KEY": ""
    },
    "_comment_academicEtiquetteEmail": "Email used for academic APIs (Crossref, Unpaywall) to identify requests and get into their polite pools. Replace with your real institutional email.",
    "academicEtiquetteEmail": "your-email@university.edu"
}
